# ── Core Security ─────────────────────────────────────────────────────────────
SMS_SECRET_KEY=change-me-in-production-use-a-long-random-string
SMS_JWT_SECRET=change-me-jwt-use-a-long-random-string

# ── Flask-Mail (leave MAIL_SUPPRESS_SEND=true while developing) ───────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@idonportal.com
MAIL_SUPPRESS_SEND=true

# ── HTTPS (set true only in production behind nginx/gunicorn with TLS) ────────
FORCE_HTTPS=false
